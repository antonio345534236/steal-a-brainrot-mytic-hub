-- =====================================
-- FALLING BOX ANIMATION (inside GUI)
-- =====================================
task.spawn(function()
	local frameWidth = frame.AbsoluteSize.X
	local frameHeight = frame.AbsoluteSize.Y

	while true do
		local box = Instance.new("Frame", frame)
		local sizeX = math.random(6,12)
		local sizeY = math.random(6,12)
		box.Size = UDim2.fromOffset(sizeX, sizeY)
		-- Spawn fully inside frame horizontally
		local spawnX = math.random(0, frameWidth - sizeX)
		box.Position = UDim2.fromOffset(spawnX, -sizeY)
		box.BackgroundColor3 = Color3.fromRGB(0,200,255)
		box.BackgroundTransparency = 0.3
		box.BorderSizePixel = 0
		Instance.new("UICorner", box).CornerRadius = UDim.new(1,0)

		-- Tween to move down to bottom of frame
		local tween = TweenService:Create(
			box,
			TweenInfo.new(1.8, Enum.EasingStyle.Linear),
			{Position = UDim2.fromOffset(spawnX, frameHeight)}
		)
		tween:Play()
		tween.Completed:Connect(function() box:Destroy() end)

		task.wait(0.08)
	end
end)
