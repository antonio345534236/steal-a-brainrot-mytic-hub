local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer
local plots = workspace:WaitForChild("Plots")

local zone

-- =====================================
-- FIND BASE
-- =====================================
local function getStructureBaseHome()
	local name = player.Name:lower()
	local display = player.DisplayName:lower()

	for _, base in ipairs(plots:GetChildren()) do
		for _, d in ipairs(base:GetDescendants()) do
			if d:IsA("TextLabel") then
				local t = d.Text:lower()
				if t:find(name,1,true) or t:find(display,1,true) then
					local dec = base:FindFirstChild("Decorations")
					if dec and dec:FindFirstChild("Model") then
						for _, p in ipairs(dec.Model:GetChildren()) do
							if p:IsA("BasePart") then
								return p
							end
						end
					end
				end
			end
		end
	end
	return nil
end

local function isInside(part,pos)
	local lp = part.CFrame:PointToObjectSpace(pos)
	local h = part.Size/2
	return math.abs(lp.X)<=h.X and math.abs(lp.Y)<=h.Y and math.abs(lp.Z)<=h.Z
end

-- =====================================
-- PROTECTION
-- =====================================
getgenv().activateProtection = function()
	if getgenv().ProtectionEnabled then return end
	getgenv().ProtectionEnabled = true

	StarterGui:SetCore("SendNotification",{
		Title="Ryxx Base Protect (Free) ON",
		Text="Player entering base = exit game",
		Duration=5
	})

	local base = getStructureBaseHome()
	if not base then return end

	zone = Instance.new("Part")
	zone.Anchored=true
	zone.CanCollide=false
	zone.Transparency=1
	zone.Size=Vector3.new(40,40,300)
	zone.CFrame=base.CFrame
	zone.Parent=workspace

	task.spawn(function()
		while getgenv().ProtectionEnabled do
			for _,plr in ipairs(Players:GetPlayers()) do
				if plr~=player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
					if isInside(zone,plr.Character.HumanoidRootPart.Position) then
						game:Shutdown()
					end
				end
			end
			task.wait(0.15)
		end
	end)
end

getgenv().deactivateProtection = function()
	getgenv().ProtectionEnabled=false
	if zone then zone:Destroy() zone=nil end
end

