local function removeAccessoriesAndClothing(char)
    if not char then return end
    for _, obj in ipairs(char:GetChildren()) do
        if obj:IsA("Accessory") or obj:IsA("Hat") or obj:IsA("HatAccessory") then obj:Destroy()
        elseif obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("ShirtGraphic") then obj:Destroy()
        elseif obj:IsA("BodyColors") then
            obj.HeadColor3=Color3.fromRGB(163,162,165); obj.LeftArmColor3=Color3.fromRGB(163,162,165)
            obj.RightArmColor3=Color3.fromRGB(163,162,165); obj.LeftLegColor3=Color3.fromRGB(163,162,165)
            obj.RightLegColor3=Color3.fromRGB(163,162,165); obj.TorsoColor3=Color3.fromRGB(163,162,165)
        end
    end
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("Decal") and obj.Name ~= "face" then obj:Destroy() end
    end
end
if Player.Character then task.defer(function() removeAccessoriesAndClothing(Player.Character) end) end
