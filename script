local function SaveConfig()
    local data = {}
    for k,v in pairs(Enabled) do data[k]=v end
    for k,v in pairs(Values) do data[k]=v end
    
    data.KEY_SPEED         = KEYBINDS.SPEED.Name
    data.KEY_BATAIMBOT     = KEYBINDS.BATAIMBOT.Name
    data.KEY_AUTORIGHT     = KEYBINDS.AUTORIGHT.Name
    data.KEY_AUTOWALK      = KEYBINDS.AUTOWALK.Name
    data.KEY_SPAMBOT       = KEYBINDS.SPAMBOT.Name
    data.KEY_NOCLIPPLAYERS = KEYBINDS.NOCLIPPLAYERS.Name
    data.KEY_DROPBRAINROT  = KEYBINDS.DROPBRAINROT.Name
    data.KEY_MEDUSA        = KEYBINDS.MEDUSA.Name
    data.KEY_INFJUMP       = KEYBINDS.INFJUMP.Name
    data.KEY_TPDOWN        = KEYBINDS.TPDOWN.Name
    data.KEY_DUELDESYNC    = KEYBINDS.DUELDESYNC.Name

    -- FIX SAVE: aspetta un frame per avere AbsolutePosition aggiornata,
    -- poi salva con ScaleX=0 e offset pixel assoluti
    data.UIPositions = {}
    for name, btn in pairs(allHUDButtons) do
        if btn and btn.Parent and btn:IsA("GuiObject") then
            local abs = btn.AbsolutePosition
            -- salva sia offset che scale corrente del Position
            data.UIPositions[name] = {
                ScaleX = btn.Position.X.Scale,
                ScaleY = btn.Position.Y.Scale,
                OffsetX = btn.Position.X.Offset,
                OffsetY = btn.Position.Y.Offset,
                -- AbsolutePosition come fallback
                AbsX = abs.X,
                AbsY = abs.Y,
            }
        end
    end

    local ok, err = pcall(function()
        if not writefile then error("writefile non disponibile") end
        writefile(ConfigFileName, HttpService:JSONEncode(data))
    end)

    if ok and SaveBtnRef then
        SaveBtnRef.Text = "✔ SAVED"
        SaveBtnRef.TextColor3 = Color3.fromRGB(255, 255, 255)
        SaveBtnRef.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        task.delay(1, function()
            if SaveBtnRef then
                SaveBtnRef.Text = "💾 SAVE"
                SaveBtnRef.TextColor3 = Color3.fromRGB(180, 180, 220)
                SaveBtnRef.BackgroundColor3 = Color3.fromRGB(15, 15, 55)
            end
        end)
    elseif not ok then
        warn("[Mytic] Errore salvataggio: " .. tostring(err))
    end
    return ok
end

