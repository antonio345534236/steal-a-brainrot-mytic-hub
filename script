    local wasDragged = false
    local PC_THRESHOLD = 4
    local MOBILE_THRESHOLD = 10
    local isMobile = UserInputService.TouchEnabled

    local function onPress(startVec2)
        if buttonsLocked then return end
        pressing = true
        wasDragged = false
        dragStart = startVec2
        startPos = frame.Position
    end

    local function onRelease()
        if buttonsLocked then
            if onClickCallback then onClickCallback() end
            return
        end
        if not pressing then return end
        pressing = false
        if not wasDragged and onClickCallback then
            onClickCallback()
        else
            if wasDragged then
                -- FIX SAVE: salva dopo UN frame così AbsolutePosition è aggiornata
                task.defer(SaveConfig)
            end
        end
        wasDragged = false
    end

    if isMobile then
        frame.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.Touch then return end
            onPress(Vector2.new(input.Position.X, input.Position.Y))
        end)
        frame.InputEnded:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.Touch then return end
            onRelease()
        end)
        frame.InputChanged:Connect(function(input)
            if not pressing then return end
            if input.UserInputType ~= Enum.UserInputType.Touch then return end
            local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStart
            if delta.Magnitude > MOBILE_THRESHOLD then
                wasDragged = true
                local vp_m = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280,720)
                local bx_m = startPos.X.Scale*vp_m.X + startPos.X.Offset
                local by_m = startPos.Y.Scale*vp_m.Y + startPos.Y.Offset
                frame.Position = UDim2.new(0, bx_m+delta.X, 0, by_m+delta.Y)
            end
        end)
    else
        if frame:IsA("TextButton") then
            frame.MouseButton1Down:Connect(function()
                onPress(UserInputService:GetMouseLocation())
            end)
            frame.MouseButton1Up:Connect(onRelease)
        else
            frame.InputBegan:Connect(function(input)
                if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                onPress(UserInputService:GetMouseLocation())
            end)
            frame.InputEnded:Connect(function(input)
                if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                onRelease()
            end)
        end
        RunService.Heartbeat:Connect(function()
            if not pressing or buttonsLocked then return end
            local delta = UserInputService:GetMouseLocation() - dragStart
            if delta.Magnitude > PC_THRESHOLD then
                wasDragged = true
                local vp_m = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280,720)
                local bx_m = startPos.X.Scale*vp_m.X + startPos.X.Offset
                local by_m = startPos.Y.Scale*vp_m.Y + startPos.Y.Offset
                frame.Position = UDim2.new(0, bx_m+delta.X, 0, by_m+delta.Y)
            end
        end)
    end
end

