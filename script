-- [[ ANTI KICK - FIX COMPLETO ]]
-- ============================================================
-- Variabili AntiKick a scope globale dello script
local antiKickEnabled = false
local antiKickConn = nil
local antiKickHookedOnce = false  -- hookfunction va chiamato UNA sola volta

local function startAntiKick()
    if antiKickConn then return end -- già attivo

    -- METODO 1: hookfunction (se disponibile nell'executor)
    -- Va eseguito UNA sola volta, non ad ogni enable/disable
    if not antiKickHookedOnce then
        antiKickHookedOnce = true
        -- Hook su Player.Kick tramite metatable
        pcall(function()
            local mt = getrawmetatable(game)
            if mt then
                setreadonly(mt, false)
                local oldNamecall = mt.__namecall
                mt.__namecall = newcclosure(function(self, ...)
                    local method = getnamecallmethod()
                    -- Blocca solo se è Kick e AntiKick è attivo
                    if antiKickEnabled and method == "Kick" and self == Player then
                        return -- blocca il kick
                    end
                    return oldNamecall(self, ...)
                end)
                setreadonly(mt, true)
            end
        end)

        -- Fallback: hookfunction diretto su Player.Kick
        pcall(function()
            if hookfunction then
                local origKick = Player.Kick
                hookfunction(origKick, newcclosure(function(self, ...)
                    if antiKickEnabled and self == Player then
                        return -- blocca
                    end
                    return origKick(self, ...)
                end))
            end
        end)
    end

    -- METODO 2: Heartbeat — mantiene il giocatore in game e resetta
    -- velocità/salute anomale che causano kick automatici del server
    antiKickConn = RunService.Heartbeat:Connect(function()
        if not antiKickEnabled then return end
        pcall(function()
            -- Previeni kick da "player left the game" riconnettendo il Parent
            if Player.Parent ~= Players then
                Player.Parent = Players
            end
        end)
        pcall(function()
            local char = Player.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            -- Blocca velocità anomale (anti-kick da exploit detection server-side)
            if hrp and hrp.AssemblyLinearVelocity.Magnitude > 500 then
                hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
            end
            -- Mantieni salute > 0 (evita death-kick)
            if hum and hum.Health <= 0 then
                hum.Health = 100
            end
        end)
    end)
end

local function stopAntiKick()
    antiKickEnabled = false
    if antiKickConn then antiKickConn:Disconnect(); antiKickConn = nil end
    -- Nota: non "de-hookkiamo" perché hookfunction non è reversibile facilmente,
    -- ma il flag antiKickEnabled=false fa sì che il hook non blocchi più nulla.
end

